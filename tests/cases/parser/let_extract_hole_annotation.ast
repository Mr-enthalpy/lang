Program
  Let
    binder:
      Extract
        deduce:
          DeduceList
            binders:
              BinderDecl name=x
                annotation:
                  Hole _
        skeleton:
          CanonicalSegment
            elements:
              CanonicalName role=Hole name=x
              CanonicalName role=NodeName name=Node
