let unit: type = uint8;
let int: type = uint16;
let runtime_residual = runtime_only_expr;

meta | runtime let + =
  (self, t: type, _ unit: type): meta -> let r: type =>
{
  r === t;
};

meta | runtime let + =
  (self, _ unit: type, t: type): meta -> let r: type =>
{
  r === t;
};

let X: type = int + unit;
let Y: type = unit + int;