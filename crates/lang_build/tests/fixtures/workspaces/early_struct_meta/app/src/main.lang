let T: type = (uint8 a, uint8 b) |> struct;

verify exists T;
verify kind T type;
verify field_names T a b;
verify kind a::T field_function;
verify kind a::ref::T field_function;
verify kind a::share::T field_function;
verify kind b::T field_function;
verify kind b::ref::T field_function;
verify kind b::share::T field_function;
verify field_projection a::T value;
verify field_projection a::ref::T ref;
verify field_projection a::share::T share;
verify field_owner a::T T;
verify field_type a::T uint8;
